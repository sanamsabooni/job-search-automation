# Environment Variables Configuration
# Copy this file to .env and fill in your actual values

# n8n Configuration
N8N_WEBHOOK_URL=https://your-n8n-instance.com/webhook/job-scraper
N8N_API_KEY=your_n8n_api_key_here

# OpenAI Configuration (for job scoring)
OPENAI_API_KEY=your_openai_api_key_here

# Job Board API Keys (if applicable)
GREENHOUSE_API_KEY=optional_greenhouse_api_key
LEVER_API_KEY=optional_lever_api_key

# Email Configuration (for notifications)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
EMAIL_FROM=your-email@gmail.com
EMAIL_PASSWORD=your_app_password
EMAIL_TO=recipient@example.com

# Database (optional)
DATABASE_URL=sqlite:///jobs.db
